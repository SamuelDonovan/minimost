{
  "name": "minimost",
  "private": true,
  "scripts": {
    "test:js": "jest --coverage",
    "lint:js": "eslint src/minimost/static",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "3.8.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/js/**/*.test.js"
    ],
    "setupFiles": [
      "./tests/js/setup.js"
    ],
    "setupFilesAfterEnv": [
      "./tests/js/setup-after.js"
    ],
    "coverageDirectory": "coverage/js",
    "collectCoverage": false,
    "collectCoverageFrom": [
      "src/minimost/static/chat-*.js"
    ],
    "coverageReporters": [
      "lcov",
      "text-summary"
    ],
    "coverageProvider": "v8",
    "transform": {}
  }
}
